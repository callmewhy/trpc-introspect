{
  "name": "@api-introspect/core",
  "type": "module",
  "version": "0.11.2",
  "description": "Framework-agnostic types and utilities for API introspection.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/callmewhy/api-introspect.git",
    "directory": "packages/core"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc --noEmit && tsdown",
    "dev": "tsdown --watch --no-clean",
    "clean": "rm -rf dist"
  }
}
