{
  "name": "@api-introspect/fastify",
  "type": "module",
  "version": "0.11.2",
  "description": "Fastify route introspection. Discover endpoints and input/output schemas.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/callmewhy/api-introspect.git",
    "directory": "packages/fastify"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc --noEmit && tsdown",
    "dev": "tsdown --watch --no-clean",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "fastify": ">=4"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    }
  },
  "dependencies": {
    "@api-introspect/core": "workspace:*",
    "fastify-plugin": "^5.1.0"
  }
}
