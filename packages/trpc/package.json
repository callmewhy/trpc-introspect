{
  "name": "@api-introspect/trpc",
  "type": "module",
  "version": "0.13.2",
  "description": "tRPC router introspection. Discover procedures, input/output schemas as JSON Schema.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/callmewhy/api-introspect.git",
    "directory": "packages/trpc"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.check.json --noEmit && tsdown",
    "dev": "tsdown --watch --no-clean",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@trpc/server": ">=11",
    "zod": ">=4"
  },
  "peerDependenciesMeta": {
    "@trpc/server": { "optional": true },
    "zod": { "optional": true }
  },
  "dependencies": {
    "@api-introspect/core": "workspace:*"
  }
}
